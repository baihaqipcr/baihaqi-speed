<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bd_bg">

    <!-- Header / Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bd_surface"
        android:elevation="4dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daftar Program"
            android:fontFamily="@font/poppins_bold"
            android:textSize="20sp"
            android:textColor="@color/bd_text_primary"/>
    </LinearLayout>

    <!-- TabLayout for Filtering -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutPrograms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bd_surface"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/bd_primary"
        app:tabIndicatorColor="@color/bd_primary"
        app:tabTextColor="@color/bd_text_secondary"
        app:tabTextAppearance="@style/TextAppearance.MaterialComponents.Subtitle2"/>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPrograms"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingVertical="8dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

</LinearLayout>