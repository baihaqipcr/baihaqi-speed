<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header teal dengan info profil -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_teal_gradient"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="20dp">

            <!-- Baris kanan: judul + ikon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hey, Wildan!"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="22sp"
                    android:textColor="@color/text_white"/>

                <!-- Avatar -->
                <ImageView
                    android:id="@+id/imgProfileAvatar"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="10dp"
                    android:backgroundTint="#00B4DB"
                    android:contentDescription="Avatar"/>
            </LinearLayout>

            <!-- Nama & Role -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Muhammad Wildan W."
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="18sp"
                    android:textColor="@color/text_white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Developer Aplikasi Bina Desa"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="12sp"
                    android:textColor="@color/text_white_70"
                    android:paddingTop="3dp"/>

                <!-- Total Transaksi/Kontribusi -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL KONTRIBUSI"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="10sp"
                        android:textColor="@color/text_white_70"
                        android:letterSpacing="0.1"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvTotalKontribusi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1.622"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_white"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- 2 Card Statistik berdampingan (sesuai desain) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Card Income / Paket Didistribusikan -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/teal_start">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_icon_circle"
                                android:gravity="center">
                                <TextView android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📦" android:textSize="15sp"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="  PAKET"
                                android:fontFamily="@font/poppins_bold"
                                android:textSize="11sp"
                                android:textColor="#CCFFFFFF"
                                android:letterSpacing="0.05"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvJumlahPaket"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="986"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="28sp"
                            android:textColor="#FFFFFF"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paket Diselesaikan"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="#CCFFFFFF"
                            android:paddingTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card Jam Kerja -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/bg_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_tag_blue"
                                android:gravity="center">
                                <TextView android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⏱️" android:textSize="15sp"/>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="  JAM KERJA"
                                android:fontFamily="@font/poppins_bold"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:letterSpacing="0.05"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvJamKerja"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="320"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="28sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jam Relawan"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:paddingTop="2dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Card Informasi Pengembang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informasi Pengembang"
                android:fontFamily="@font/poppins_bold"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Row: NIM -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="NIM"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12345678"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/border_light"/>

                    <!-- Row: Program Studi -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Program Studi"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Informatika"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/border_light"/>

                    <!-- Row: Universitas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Universitas"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Universitas XYZ"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="@color/border_light"/>

                    <!-- Row: Role -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Role"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Developer Aplikasi Bina Desa"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/teal_start"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tombol Logout -->
            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Keluar Akun"
                android:fontFamily="@font/poppins_bold"
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:background="@drawable/bg_yellow_btn"
                android:stateListAnimator="@null"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>