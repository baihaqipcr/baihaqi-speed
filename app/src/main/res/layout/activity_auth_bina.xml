<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bd_bg">

    <!-- Header image -->
    <ImageView
        android:id="@+id/imgAuthHeader"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bd_bg_splash"
        android:contentDescription="Auth Header Background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Overlay gelap pada header -->
    <View
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="#661A2340"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Logo + judul di atas header -->
    <LinearLayout
        android:id="@+id/layoutAuthHeader"
        android:layout_width="0dp"
        android:layout_height="260dp"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌾"
            android:textSize="40sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bina Desa"
            android:fontFamily="@font/poppins_bold"
            android:textSize="28sp"
            android:textColor="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bantuan Sosial &amp; Sembako"
            android:fontFamily="@font/poppins_regular"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Card form login -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAuthForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="-32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/bd_surface"
        app:layout_constraintTop_toBottomOf="@id/imgAuthHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masuk Akun"
                android:fontFamily="@font/poppins_bold"
                android:textSize="20sp"
                android:textColor="@color/bd_text_primary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Masuk untuk mengakses program bantuan"
                android:fontFamily="@font/poppins_regular"
                android:textSize="12sp"
                android:textColor="@color/bd_text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Username -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUsername"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:hint="Username / NIK"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/bd_primary"
                app:hintTextColor="@color/bd_text_secondary"
                app:startIconDrawable="@drawable/ic_user"
                app:startIconTint="@color/bd_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="13sp"
                    android:textColor="@color/bd_text_primary"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="Password"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/bd_primary"
                app:hintTextColor="@color/bd_text_secondary"
                app:startIconDrawable="@drawable/ic_lock"
                app:startIconTint="@color/bd_primary"
                app:endIconMode="password_toggle">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="13sp"
                    android:textColor="@color/bd_text_primary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Tombol Login -->
            <Button
                android:id="@+id/btnAuthLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Masuk"
                android:fontFamily="@font/poppins_bold"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bd_bg_primary_btn"
                android:stateListAnimator="@null"
                android:layout_marginBottom="16dp"/>

            <!-- Tombol Register -->
            <TextView
                android:id="@+id/tvToRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Belum punya akun? Daftar Sekarang"
                android:fontFamily="@font/poppins_regular"
                android:textSize="13sp"
                android:textColor="@color/bd_primary"
                android:gravity="center"
                android:padding="8dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Info demo login -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Demo: login dengan akun yang sudah didaftarkan"
        android:fontFamily="@font/poppins_regular"
        android:textSize="11sp"
        android:textColor="@color/bd_text_hint"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardAuthForm"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>