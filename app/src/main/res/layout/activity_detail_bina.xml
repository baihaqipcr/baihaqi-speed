<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bd_bg">

    <!-- AppBar dengan gambar collapse -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/bd_primary">

            <ImageView
                android:id="@+id/imgDetailHero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bd_img_sembako"
                app:layout_collapseMode="parallax"/>

            <!-- Overlay gradient -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#551A2340"/>

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_back_white">

                <!-- WebView button di toolbar detail -->
                <ImageButton
                    android:id="@+id/btnWebView"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bd_bg_heart"
                    android:padding="7dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:backgroundTint="@color/bd_primary"
                    android:contentDescription="Web View"/>
            </androidx.appcompat.widget.Toolbar>
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Konten detail -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Nama program + tombol peta -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bansos Sembako"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="22sp"
                    android:textColor="@color/bd_text_primary"/>

                <TextView
                    android:id="@+id/tvShowMap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat peta"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="12sp"
                    android:textColor="@color/bd_primary"/>
            </LinearLayout>

            <!-- Rating -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="★"
                    android:textSize="14sp"
                    android:textColor="@color/bd_star"/>

                <TextView
                    android:id="@+id/tvDetailRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 4.8"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="14sp"
                    android:textColor="@color/bd_text_primary"/>

                <TextView
                    android:id="@+id/tvDetailReviews"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" (1.200 Penerima)"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="13sp"
                    android:textColor="@color/bd_text_secondary"/>
            </LinearLayout>

            <!-- Deskripsi -->
            <TextView
                android:id="@+id/tvDetailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Program Bantuan Sosial Sembako merupakan program pemerintah yang bertujuan meringankan beban masyarakat kurang mampu melalui pemberian sembako berkualitas secara langsung ke rumah tangga sasaran..."
                android:fontFamily="@font/poppins_regular"
                android:textSize="13sp"
                android:textColor="@color/bd_text_secondary"
                android:lineSpacingExtra="5dp"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selengkapnya ▾"
                android:fontFamily="@font/poppins_bold"
                android:textSize="12sp"
                android:textColor="@color/bd_primary"
                android:layout_marginBottom="24dp"/>

            <!-- Fasilitas -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Isi Paket"
                android:fontFamily="@font/poppins_bold"
                android:textSize="17sp"
                android:textColor="@color/bd_text_primary"
                android:layout_marginBottom="14dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="28dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bd_bg_facilities"
                    android:padding="12dp" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🍚" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Beras" android:fontFamily="@font/poppins_regular"
                        android:textSize="10sp" android:textColor="@color/bd_text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bd_bg_facilities"
                    android:padding="12dp" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🛢️" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Minyak" android:fontFamily="@font/poppins_regular"
                        android:textSize="10sp" android:textColor="@color/bd_text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bd_bg_facilities"
                    android:padding="12dp" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🥚" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Telur" android:fontFamily="@font/poppins_regular"
                        android:textSize="10sp" android:textColor="@color/bd_text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center" android:background="@drawable/bd_bg_facilities"
                    android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧂" android:textSize="22sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Gula" android:fontFamily="@font/poppins_regular"
                        android:textSize="10sp" android:textColor="@color/bd_text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Harga & CTA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nilai Bantuan"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="12sp"
                        android:textColor="@color/bd_text_secondary"/>
                    <TextView
                        android:id="@+id/tvDetailPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 200.000"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="22sp"
                        android:textColor="@color/bd_green"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnDaftar"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="Daftar Sekarang  →"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bd_bg_primary_btn"
                    android:paddingHorizontal="24dp"
                    android:stateListAnimator="@null"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>