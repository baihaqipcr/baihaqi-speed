<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bd_bg">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Light"
        android:background="@color/bd_bg"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bd_bg"
            app:layout_scrollFlags="scroll|enterAlways">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selamat Datang,"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="12sp"
                        android:textColor="@color/bd_text_secondary"/>

                    <TextView
                        android:id="@+id/tvToolbarTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bina Desa"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="20sp"
                        android:textColor="@color/bd_text_primary"/>
                </LinearLayout>

                <!-- WebView button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWebView"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:icon="@android:drawable/ic_menu_view"
                    app:iconTint="@color/bd_primary"
                    app:iconPadding="0dp"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    android:contentDescription="Web View"/>
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Konten utama -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search bar with custom drawable background -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSearch"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:hint="Cari program bantuan..."
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/bd_primary"
                app:hintTextColor="@color/bd_text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginBottom="24dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSemua"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Semua"
                        android:checked="true"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSembako"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sembako"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipKesehatan"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kesehatan"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPendidikan"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pendidikan"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Section: Layanan Desa (Using GridLayout) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Layanan Desa"
                android:fontFamily="@font/poppins_bold"
                android:textSize="18sp"
                android:textColor="@color/bd_text_primary"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="14dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="28dp">

                <!-- Layanan 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/bd_bg_card_gradient">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📋" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Administrasi" android:fontFamily="@font/poppins_bold"
                            android:textSize="12sp" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Layanan 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/bd_bg_card_gradient">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🚑" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ambulans" android:fontFamily="@font/poppins_bold"
                            android:textSize="12sp" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Layanan 3 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/bd_bg_card_gradient">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌾" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pertanian" android:fontFamily="@font/poppins_bold"
                            android:textSize="12sp" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Layanan 4 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/bd_bg_card_gradient">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💡" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pengaduan" android:fontFamily="@font/poppins_bold"
                            android:textSize="12sp" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- Section: Populer (Original style but refined) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Program Unggulan"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="18sp"
                    android:textColor="@color/bd_text_primary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/tvSeeAllPopular"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat semua"
                    android:textAllCaps="false"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="13sp"
                    android:textColor="@color/bd_primary"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="20dp"
                android:layout_marginBottom="28dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingEnd="20dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPopular1"
                        android:layout_width="200dp"
                        android:layout_height="240dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <ImageView android:id="@+id/imgCard1"
                                android:layout_width="match_parent" android:layout_height="match_parent"
                                android:scaleType="centerCrop" android:src="@drawable/img_hero_custom1"/>
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bd_bg_card_overlay"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:layout_alignParentBottom="true"
                                android:padding="16dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Bansos Sembako" android:fontFamily="@font/poppins_bold"
                                    android:textSize="14sp" android:textColor="#FFFFFF"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="1.200 Penerima" android:fontFamily="@font/poppins_regular"
                                    android:textSize="11sp" android:textColor="#CCFFFFFF"/>
                            </LinearLayout>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardPopular2"
                        android:layout_width="200dp"
                        android:layout_height="240dp"
                        android:layout_marginEnd="16dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="4dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                            <ImageView android:id="@+id/imgCard2"
                                android:layout_width="match_parent" android:layout_height="match_parent"
                                android:scaleType="centerCrop" android:src="@drawable/img_hero_custom2"/>
                            <View android:layout_width="match_parent" android:layout_height="match_parent"
                                android:background="@drawable/bd_bg_card_overlay"/>
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:layout_alignParentBottom="true"
                                android:padding="16dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Bedah Rumah" android:fontFamily="@font/poppins_bold"
                                    android:textSize="14sp" android:textColor="#FFFFFF"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="856 Unit" android:fontFamily="@font/poppins_regular"
                                    android:textSize="11sp" android:textColor="#CCFFFFFF"/>
                            </LinearLayout>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>