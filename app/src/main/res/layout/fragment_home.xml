<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bd_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:elevation="0dp"
        android:background="@android:color/transparent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="invisible" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/headerLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_teal_gradient"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="36dp"
                android:paddingHorizontal="20dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat Datang ke, "
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="12sp"
                            android:textColor="@color/text_white_70"/>

                        <TextView
                            android:id="@+id/tvWelcomeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Relawan Bina Desa"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="22sp"
                            android:textColor="@color/text_white"/>
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivHomeSettings"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="#FFFFFF"
                        android:background="@drawable/bg_avatar_circle"
                        android:padding="8dp"
                        android:contentDescription="Settings"/>
                </RelativeLayout>
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSearch"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:hint="Cari bantuan..."
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxBackgroundColor="@color/bd_surface"
                app:boxStrokeColor="@color/bd_primary"
                app:hintTextColor="@color/bd_text_hint"
                app:layout_constraintTop_toBottomOf="@id/headerLayout"
                app:layout_constraintBottom_toBottomOf="@id/headerLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <HorizontalScrollView
                android:id="@+id/scrollViewChips"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/tilSearch"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSemua"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Semua"
                        android:checked="true"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSembako"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sembako"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipKesehatan"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kesehatan"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPendidikan"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pendidikan"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/textView2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Layanan Desa"
                android:fontFamily="@font/poppins_bold"
                android:textSize="17sp"
                android:textColor="@color/bd_text_primary"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/scrollViewChips"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <GridLayout
                android:id="@+id/grid_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:paddingHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/textView2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/bd_bg_card_gradient">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📋" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Administrasi" android:fontFamily="@font/poppins_bold"
                            android:textSize="12sp" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/bd_bg_card_gradient">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🚑" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ambulans" android:fontFamily="@font/poppins_bold"
                            android:textSize="12sp" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <TextView
                android:id="@+id/tvGaleriTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Galeri Kegiatan"
                android:fontFamily="@font/poppins_bold"
                android:textSize="17sp"
                android:textColor="@color/bd_text_primary"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/grid_button"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnRefresh"/>

            <Button
                android:id="@+id/btnRefresh"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refresh Fakta"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/bd_primary"
                app:layout_constraintBaseline_toBaselineOf="@id/tvGaleriTitle"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/tvCatFact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Fakta tentang kucing akan muncul di sini..."
                android:fontFamily="@font/poppins_regular"
                android:textSize="12sp"
                android:textColor="@color/bd_text_hint"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/tvGaleriTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGallery"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:padding="4dp"
                android:nestedScrollingEnabled="false"
                app:layout_constraintHeight_default="wrap"
                app:layout_constraintTop_toBottomOf="@id/tvCatFact"
                app:layout_constraintBottom_toTopOf="@id/btnExploreMore"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExploreMore"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:text="Lihat Semua Program →"
                android:fontFamily="@font/poppins_bold"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                android:backgroundTint="@color/bd_primary"
                app:layout_constraintTop_toBottomOf="@id/rvGallery"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>