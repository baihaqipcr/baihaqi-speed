<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===== HEADER TEAL ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_teal_gradient"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingBottom="32dp"
            android:paddingHorizontal="20dp">

            <!-- Baris atas: greeting + ikon settings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selamat Datang,"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_white_70"/>

                    <TextView
                        android:id="@+id/tvWelcomeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Relawan Bina Desa"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="20sp"
                        android:textColor="@color/text_white"/>
                </LinearLayout>

                <!-- Ikon setting -->
                <ImageView
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:backgroundTint="#FFFFFF"
                    android:background="@drawable/bg_avatar_circle"
                    android:padding="8dp"
                    android:contentDescription="Settings"/>
            </LinearLayout>

            <!-- Statistik utama -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL PAKET TERSALURKAN"
                android:fontFamily="@font/poppins_regular"
                android:textSize="11sp"
                android:textColor="@color/text_white_70"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvTotalPaket"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.250 Paket"
                android:fontFamily="@font/poppins_bold"
                android:textSize="36sp"
                android:textColor="@color/text_white"
                android:layout_marginBottom="8dp"/>

            <!-- Badge naik -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_tag_green"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▲ 8.5% bulan ini"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="11sp"
                    android:textColor="#27AE60"/>
            </LinearLayout>

            <!-- 3 statistik kecil di bawah -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <!-- Stat 1 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="986"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_white"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KK Penerima"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="10sp"
                        android:textColor="@color/text_white_70"/>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="#33FFFFFF"/>

                <!-- Stat 2 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_white"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Desa Aktif"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="10sp"
                        android:textColor="@color/text_white_70"/>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="#33FFFFFF"/>

                <!-- Stat 3 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="48"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="18sp"
                        android:textColor="@color/text_white"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Relawan"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="10sp"
                        android:textColor="@color/text_white_70"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== BODY PUTIH ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Button Baru untuk ke DetailBinaActivity -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailBina"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Detail Bina Desa"
                android:textAllCaps="false"
                android:fontFamily="@font/poppins_bold"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="20dp"
                app:icon="@android:drawable/ic_menu_info_details"
                android:backgroundTint="@color/teal_start"/>

            <!-- Label Kegiatan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kegiatan Terbaru"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat Semua"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="12sp"
                    android:textColor="@color/teal_start"/>
            </LinearLayout>

            <!-- Card Kegiatan 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <!-- Ikon -->
                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tag_green"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌾" android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distribusi Beras Desa Sukamakmur"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="120 KK • 17 November 2024"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:paddingTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selesai"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="10sp"
                        android:textColor="#27AE60"
                        android:background="@drawable/bg_tag_green"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Kegiatan 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tag_blue"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📋" android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pengecekan Data Warga RT 03"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85 Warga • 18 November 2024"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:paddingTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Proses"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="10sp"
                        android:textColor="@color/color_info"
                        android:background="@drawable/bg_tag_blue"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Kegiatan 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tag_orange"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛢️" android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distribusi Minyak Goreng Desa B"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="200 KK • 19 November 2024"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:paddingTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="10sp"
                        android:textColor="@color/color_warning"
                        android:background="@drawable/bg_tag_orange"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>