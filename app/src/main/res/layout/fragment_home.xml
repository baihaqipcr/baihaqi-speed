<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bd_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Custom Header Background Drawable -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_teal_gradient"
                android:orientation="vertical"
                android:paddingTop="32dp"
                android:paddingBottom="24dp"
                android:paddingHorizontal="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat Datang ke, "
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="12sp"
                            android:textColor="@color/text_white_70"/>

                        <TextView
                            android:id="@+id/tvWelcomeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Relawan Bina Desa"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="22sp"
                            android:textColor="@color/text_white"/>
                    </LinearLayout>

                    <!-- Settings Icon -->
                    <ImageView
                        android:id="@+id/ivHomeSettings"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@android:drawable/ic_menu_manage"
                        app:tint="#FFFFFF"
                        android:background="@drawable/bg_avatar_circle"
                        android:padding="8dp"
                        android:contentDescription="Settings"/>
                </RelativeLayout>
            </LinearLayout>

            <!-- TextInputLayout Search (Material) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilSearch"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="-24dp"
                android:hint="Cari bantuan..."
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxBackgroundColor="@color/bd_surface"
                app:boxStrokeColor="@color/bd_primary"
                app:hintTextColor="@color/bd_text_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="14sp"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Chip & ChipGroup -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="24dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupCategories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSemua"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Semua"
                        android:checked="true"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSembako"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sembako"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipKesehatan"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kesehatan"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPendidikan"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pendidikan"
                        app:chipBackgroundColor="@color/bd_bg_chip_state_list"
                        android:textColor="@color/bd_chip_text_state_list"/>

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- GridLayout for Services -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Layanan Desa"
                android:fontFamily="@font/poppins_bold"
                android:textSize="17sp"
                android:textColor="@color/bd_text_primary"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/bd_bg_card_gradient">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📋" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Administrasi" android:fontFamily="@font/poppins_bold"
                            android:textSize="12sp" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="16dp"
                        android:background="@drawable/bd_bg_card_gradient">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🚑" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ambulans" android:fontFamily="@font/poppins_bold"
                            android:textSize="12sp" android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <!-- MaterialButton CTA -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExploreMore"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="20dp"
                android:text="Lihat Semua Program →"
                android:fontFamily="@font/poppins_bold"
                android:textAllCaps="false"
                app:cornerRadius="14dp"
                android:backgroundTint="@color/bd_primary"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>