<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- ===== HEADER (judul + deskripsi dari HomeActivity) ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_subpage_header"
        android:orientation="vertical"
        android:paddingTop="44dp"
        android:paddingBottom="20dp"
        android:paddingHorizontal="20dp">

        <!-- Tombol Back -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="@drawable/bg_edittext_glass"
            android:backgroundTint="@color/white"
            android:contentDescription="Kembali"
            android:layout_marginBottom="12dp"/>

        <!-- Judul dari HomeActivity -->
        <TextView
            android:id="@+id/tvFromHomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HQSpaces"
            android:fontFamily="@font/poppins_bold"
            android:textSize="11sp"
            android:textColor="@color/text_white_70"
            android:letterSpacing="0.1"/>

        <!-- Judul halaman ini -->
        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bangun Ruang"
            android:fontFamily="@font/poppins_bold"
            android:textSize="22sp"
            android:textColor="@color/white"/>

        <!-- Deskripsi dari HomeActivity -->
        <TextView
            android:id="@+id/tvFromHomeDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deskripsi dari home"
            android:fontFamily="@font/poppins_regular"
            android:textSize="11sp"
            android:textColor="@color/text_white_70"
            android:paddingTop="4dp"/>
    </LinearLayout>

    <!-- ===== KONTEN HALAMAN ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Hero Image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:src="@drawable/img_hero_bangun"
                android:scaleType="fitCenter"
                android:layout_marginBottom="20dp"/>

            <!-- Card: Volume Balok -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volume Balok"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rumus: V = p × l × t"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <EditText
                            android:id="@+id/etPanjang"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:hint="Panjang"
                            android:inputType="numberDecimal"
                            android:background="@drawable/bg_edittext_glass"
                            android:padding="10dp"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginEnd="6dp"/>

                        <EditText
                            android:id="@+id/etLebar"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:hint="Lebar"
                            android:inputType="numberDecimal"
                            android:background="@drawable/bg_edittext_glass"
                            android:padding="10dp"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginEnd="6dp"/>

                        <EditText
                            android:id="@+id/etTinggi"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:hint="Tinggi"
                            android:inputType="numberDecimal"
                            android:background="@drawable/bg_edittext_glass"
                            android:padding="10dp"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnHitungBalok"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="Hitung Volume Balok"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primary_800"
                        android:stateListAnimator="@null"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvHasilBalok"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hasil: -"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Volume Tabung -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volume Tabung"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rumus: V = π × r² × t"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <EditText
                            android:id="@+id/etJariJari"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:hint="Jari-jari (r)"
                            android:inputType="numberDecimal"
                            android:background="@drawable/bg_edittext_glass"
                            android:padding="10dp"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginEnd="8dp"/>

                        <EditText
                            android:id="@+id/etTinggiTabung"
                            android:layout_width="0dp"
                            android:layout_height="46dp"
                            android:layout_weight="1"
                            android:hint="Tinggi (t)"
                            android:inputType="numberDecimal"
                            android:background="@drawable/bg_edittext_glass"
                            android:padding="10dp"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnHitungTabung"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="Hitung Volume Tabung"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/cyan_800"
                        android:stateListAnimator="@null"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvHasilTabung"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hasil: -"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:gravity="center"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>