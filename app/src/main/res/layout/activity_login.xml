<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ===== BAGIAN ATAS: Logo & Judul ===== -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="60dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_logo"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HQSpaces"
            android:textAppearance="@style/TextAppearance.AquaFlow.Title"
            android:textSize="32sp"/>

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your smart spaces calculator"
            android:textAppearance="@style/TextAppearance.AquaFlow.Tagline"
            android:gravity="center"
            android:paddingTop="6dp"/>

    </LinearLayout>

    <!-- ===== CARD FORM LOGIN ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#F0FAFF"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:fontFamily="@font/poppins_bold"
                android:textSize="20sp"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvNewUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New user? Create an account"
                android:fontFamily="@font/poppins_regular"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:layout_marginBottom="20dp"/>

            <!-- Input Username -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:errorEnabled="true"
                android:layout_marginBottom="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_edittext_glass"
                    android:padding="4dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_user"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"/>
                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Username"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_dark"
                        android:background="@null"
                        android:inputType="text"
                        android:singleLine="true"/>
                </LinearLayout>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Input Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:errorEnabled="true"
                app:passwordToggleEnabled="true"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_edittext_glass"
                    android:padding="4dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_lock"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"/>
                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Password"
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_dark"
                        android:background="@null"
                        android:inputType="textPassword"
                        android:singleLine="true"/>
                </LinearLayout>
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Continue"
                android:fontFamily="@font/poppins_bold"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:background="@drawable/btn_login_gradient"
                android:stateListAnimator="@null"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— OR —"
                android:fontFamily="@font/poppins_regular"
                android:textSize="11sp"
                android:textColor="#90CAF9"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnGoogle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="  Continue with Google"
                android:fontFamily="@font/poppins_regular"
                android:textSize="13sp"
                android:textColor="@color/text_dark"
                android:background="@drawable/btn_outline"
                android:stateListAnimator="@null"
                android:drawableStart="@drawable/ic_google"
                android:drawablePadding="8dp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <View
        android:id="@+id/bottomSpacer"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        app:layout_constraintTop_toBottomOf="@id/cardLogin"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>