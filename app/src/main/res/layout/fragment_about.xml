<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header teal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_teal_gradient"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="48dp"
            android:paddingBottom="28dp"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌾"
                android:textSize="40sp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Program Bina Desa"
                android:fontFamily="@font/poppins_bold"
                android:textSize="22sp"
                android:textColor="@color/text_white"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bansos &amp; Sembako Tepat Sasaran"
                android:fontFamily="@font/poppins_regular"
                android:textSize="13sp"
                android:textColor="@color/text_white_70"
                android:gravity="center"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- Body -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card Definisi -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="20dp"
                            android:background="@color/teal_start"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tentang Program"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aplikasi Bina Desa adalah platform digital yang dirancang untuk memantau, mendata, dan memastikan pemanfaatan sembako bagi warga yang membutuhkan. Program ini hadir sebagai wujud nyata transparansi dan akuntabilitas distribusi bantuan sosial di tingkat desa."
                        android:fontFamily="@font/poppins_regular"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingExtra="5dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Label Fitur -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fitur Utama Aplikasi"
                android:fontFamily="@font/poppins_bold"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <!-- Card Fitur 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tag_blue"
                        android:gravity="center"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👤" android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pendataan Penerima"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Registrasi dan verifikasi data warga penerima bantuan sosial secara akurat"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingExtra="3dp"
                            android:paddingTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Fitur 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tag_green"
                        android:gravity="center"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📦" android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tracking Distribusi Sembako"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pantau proses distribusi sembako secara real-time dari gudang hingga ke tangan penerima"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingExtra="3dp"
                            android:paddingTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Fitur 3 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_tag_orange"
                        android:gravity="center"
                        android:layout_marginEnd="14dp">
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊" android:textSize="20sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Laporan Transparansi"
                            android:fontFamily="@font/poppins_bold"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Laporan distribusi yang transparan dan dapat diakses oleh seluruh pemangku kepentingan"
                            android:fontFamily="@font/poppins_regular"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingExtra="3dp"
                            android:paddingTop="3dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Versi aplikasi -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Versi 1.0.0 • © 2024 Bina Desa Team"
                android:fontFamily="@font/poppins_regular"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>