<resources>
    <style name="Theme.AquaFlow" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/gradientStart</item>
    </style>

    <!-- Base style for AquaFlow text appearances to avoid AAPT linking errors -->
    <style name="TextAppearance.AquaFlow" parent="android:TextAppearance" />

    <!-- Custom font styles -->
    <style name="TextAppearance.AquaFlow.Title">
        <item name="android:fontFamily">@font/poppins_bold</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.AquaFlow.Tagline">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white_70</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.AquaFlow.Body">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_dark</item>
    </style>

    <style name="Theme.BinaDesa" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/teal_start</item>
        <item name="colorPrimaryVariant">@color/teal_end</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/accent_yellow</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:statusBarColor">@color/teal_end</item>
    </style>

    <style name="BottomNavText">
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">11sp</item>
    </style>

</resources>